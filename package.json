{
  "name": "@omophub/omophub-node",
  "version": "0.0.1",
  "description": "Official OMOPHub Node.js / TypeScript SDK for the OHDSI medical vocabularies API - search, lookup, map, and navigate concepts across SNOMED, ICD10, RxNorm, LOINC, and more.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write src/ test/",
    "format:check": "biome format --check src/ test/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "omophub",
    "ohdsi",
    "omop",
    "medical-vocabularies",
    "snomed",
    "icd10",
    "rxnorm",
    "loinc",
    "healthcare",
    "clinical-data",
    "vocabulary-mapping",
    "concept-mapping",
    "fhir",
    "athena",
    "sdk"
  ],
  "author": "OMOPHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OMOPHub/omophub-node.git"
  },
  "bugs": {
    "url": "https://github.com/OMOPHub/omophub-node/issues"
  },
  "homepage": "https://omophub.com",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
